{
	"name": "node-api",
	"version": "1.0.3",
	"main": "index.js",
	"scripts": {
		"dev": "tsx --watch --env-file .env src/shared/infra/http/server.ts",
		"build": "tsup src/shared/infra/http/server.ts --format cjs --dts --out-dir dist --clean",
		"start": "node -r tsconfig-paths/register dist/server.js",
		"format": "biome format --write",
		"lint": "biome check --write",
		"test": "vitest"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@types/node": "^25.9.3",
		"@types/pg": "^8.20.0",
		"prisma": "^7.8.0",
		"tsup": "^8.5.0",
		"tsx": "^4.20.6",
		"typescript": "^5"
	},
	"dependencies": {
		"@fastify/cors": "^11.1.0",
		"@fastify/jwt": "^10.0.0",
		"@fastify/rate-limit": "^10.3.0",
		"@fastify/swagger": "^9.5.2",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@scalar/fastify-api-reference": "^1.39.2",
		"dotenv": "^17.4.2",
		"fastify": "^5.6.1",
		"fastify-type-provider-zod": "^6.1.0",
		"module-alias": "^2.2.3",
		"pg": "^8.21.0",
		"tsconfig-paths": "^4.2.0",
		"zod": "^4.1.12"
	}
}
